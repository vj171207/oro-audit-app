rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Both collections require a signed-in @orocorp.in Google account.
    // This is defense in depth alongside the app's own login screen — even
    // someone who found the Firestore project reference directly, bypassing
    // the app entirely, can't read or write without a valid Oro login.
    function isOroUser() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@orocorp[.]in$');
    }

    // Manager check for config/cities writes. Looks up config/managers
    // (emails stored lowercase there) rather than using custom claims,
    // since custom claims require a Cloud Function, which needs the paid
    // Blaze plan. This get() costs one extra read per write attempt —
    // trivial at this app's scale.
    function isManager() {
      return isOroUser()
        && exists(/databases/$(database)/documents/config/managers)
        && request.auth.token.email.lower() in get(/databases/$(database)/documents/config/managers).data.emails;
    }

    match /calibrations/{calibrationId} {
      allow read: if isOroUser();
      allow create: if isOroUser()
                    && request.resource.data.keys().hasAll(
                        ['city','testDate','monthYearLabel','auditorName','auditorEmpCode',
                         'apName','apEmpCode','apDoj','needles','totalScore',
                         'autoFailTriggered','result'])
                    && request.resource.data.city is string
                    && request.resource.data.totalScore is number
                    && request.resource.data.totalScore >= 0
                    && request.resource.data.totalScore <= 10
                    && request.resource.data.result in ['Pass', 'Fail']
                    && request.resource.data.needles is list
                    && request.resource.data.needles.size() == 5;
      allow update, delete: if false;
    }

    match /interview_entries/{entryId} {
      allow read: if isOroUser();
      // Mirrors calibrations' rigor above — this used to only require 3
      // fields (city/interviewDate/candidateName) while every other field
      // on the form was already mandatory client-side, an asymmetry that
      // meant anyone bypassing the UI (direct API call, a future bug in the
      // client validation) could write a record missing everything else,
      // or with an out-of-range score, and Firestore would accept it.
      allow create: if isOroUser()
                    && request.resource.data.keys().hasAll(
                        ['city','interviewDate','candidateName','locationDetail','company','role',
                         'age','experience','bikeAvailable','dlAvailable','scoreTheory','scorePractical',
                         'totalScore','localLanguage','localLanguageProficiency','englishProficiency',
                         'round1Decision','interviewer'])
                    && request.resource.data.city is string
                    && request.resource.data.candidateName is string
                    && request.resource.data.candidateName.size() > 0
                    && request.resource.data.scoreTheory is number
                    && request.resource.data.scoreTheory >= 0
                    && request.resource.data.scoreTheory <= 4
                    && request.resource.data.scorePractical is number
                    && request.resource.data.scorePractical >= 0
                    && request.resource.data.scorePractical <= 6
                    && request.resource.data.totalScore is number
                    && request.resource.data.totalScore >= 0
                    && request.resource.data.totalScore <= 10
                    && request.resource.data.bikeAvailable in ['Yes', 'No']
                    && request.resource.data.dlAvailable in ['Yes - DL', 'Yes - LLR', 'No']
                    && request.resource.data.round1Decision in ['Selected', 'Rejected'];
      allow update, delete: if false; // audit integrity, same as calibrations
    }

    match /appraisal_partners/{empCode} {
      allow read: if isOroUser();
      allow write: if false; // writes only via the Apps Script service account (IAM), never from the app
    }

    match /config/cities {
      allow read: if isOroUser();
      allow write: if isManager() && request.resource.data.list is list;
    }

    match /config/auditors {
      allow read: if isOroUser();
      allow write: if isManager() && request.resource.data.list is list;
    }

    match /config/cityLanguages {
      allow read: if isOroUser();
      allow write: if isManager() && request.resource.data.map is map;
    }

    match /config/managers {
      allow read: if isOroUser();
      allow write: if false; // edited manually via Firebase Console only, not self-service
    }

    match /{document=**} {
      allow read, write: if false; // deny-by-default for anything not explicitly covered above
    }
  }
}
